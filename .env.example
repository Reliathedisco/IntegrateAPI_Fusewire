# OpenAI (Support chat: embeddings required; chat default unless SUPPORT_LLM_PROVIDER=anthropic)
OPENAI_API_KEY=sk-...
# Optional override for support chat completions (default gpt-4o-mini)
# OPENAI_CHAT_MODEL=gpt-4o-mini

# Postgres + pgvector for support RAG (Neon / Supabase Postgres). After migrate + ingest, set:
# DATABASE_URL=postgresql://...
# SUPPORT_VECTOR_BACKEND=postgres

# Support escalation email (Resend)
# RESEND_API_KEY=re_...
# SUPPORT_ESCALATION_TO=support@your-domain.com
# SUPPORT_ESCALATION_FROM="IntegrateAPI <hello@your-domain.com>"

# Clerk Authentication
# Vercel production (integrateapi.io): set pk_live_ / sk_live_ in the dashboard (not necessarily in this file).
# Local: pk_test_ / sk_test_ here, OR use production keys plus NEXT_PUBLIC_*_DEV / CLERK_SECRET_KEY_DEV for localhost.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Optional — if the main vars above are production keys (pk_live_ / sk_live_), set these Development
# keys for `npm run dev` only. Production (`next build` / Vercel) never reads _DEV.
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY_DEV=pk_test_...
# CLERK_SECRET_KEY_DEV=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# App
# Public base URL used for Stripe redirect/return URLs
NEXT_PUBLIC_URL=https://your-production-domain.com

# Optional legacy fallback:
# NEXT_PUBLIC_APP_URL=https://your-production-domain.com

# Stripe Payments
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_1T8RzUPdD9uuGx4XdB7t74dI

# Resend (FuseWire newsletter)
RESEND_API_KEY=re_...
# Optional: Segment ID to group FuseWire subscribers
RESEND_FUSEWIRE_SEGMENT_ID=78261eea-8f8b-4381-83c6-79fa7120f1cf
NEWSLETTER_FROM="FuseWire <newsletter@your-production-domain.com>"
NEWSLETTER_REPLY_TO="hello@your-production-domain.com"

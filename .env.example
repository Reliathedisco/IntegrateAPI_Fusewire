# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# App
# Public base URL used for Stripe redirect/return URLs
NEXT_PUBLIC_URL=https://your-production-domain.com

# Optional legacy fallback:
# NEXT_PUBLIC_APP_URL=https://your-production-domain.com

# Stripe Payments
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_1T8RzUPdD9uuGx4XdB7t74dI

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/integrateapi

# Resend (FuseWire newsletter)
RESEND_API_KEY=re_...
# Audience ID for Resend contacts (required for newsletter signup)
RESEND_AUDIENCE_ID=your-audience-id
# Optional: Segment ID to group FuseWire subscribers
RESEND_FUSEWIRE_SEGMENT_ID=78261eea-8f8b-4381-83c6-79fa7120f1cf
NEWSLETTER_FROM="FuseWire <newsletter@your-production-domain.com>"
NEWSLETTER_REPLY_TO="hello@your-production-domain.com"
